# Kutt URL Shortener Configuration
DEFAULT_DOMAIN=localhost:3001
PORT=3001
SITE_NAME=Make Nashville Links

# Database (shared Postgres instance, separate database)
DB_CLIENT=pg
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kutt
DB_USER=kutt
DB_PASSWORD=kutt

# Redis (shared instance, DB index 1 to isolate from Outline on DB 0)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1

# Auth
JWT_SECRET=local-dev-jwt-secret-change-in-production
DISALLOW_REGISTRATION=true
DISALLOW_ANONYMOUS_LINKS=true
DISALLOW_LOGIN_FORM=true
MAIL_ENABLED=false
ADMIN_EMAILS=admin@makenashville.org

# Networking
TRUST_PROXY=true
